{
  "name": "monkey-type-cli",
  "version": "1.0.0",
  "description": "Terminal-based typing speed test inspired by MonkeyType. Built with Ink and React.",
  "main": "dist/index.js",
  "bin": {
    "monkey-type-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "typing",
    "typing-test",
    "wpm",
    "monkeytype",
    "cli",
    "terminal",
    "ink"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "ink": "^6.8.0",
    "meow": "^14.1.0",
    "react": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
